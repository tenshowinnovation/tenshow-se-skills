# Node / package managers
# pnpm-lock.yaml IS committed — needed for reproducible installs in CI.
# Other lockfiles are excluded so accidental npm/yarn use doesn't leak in.
node_modules/
package-lock.json
yarn.lock

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# Apple Sign-In private keys — NEVER commit
AuthKey_*.p8

# Env files — secrets live here
.env
.env.local
.env.*.local

# Test outputs
tests/**/.report/
tests/workflow/**/workspace/
tests/workflow/**/.snapshots/
*.log

# Husky internals — only commit our own hook scripts in .husky/, not the runtime
.husky/_/

# Python (app-store-screenshots upload helpers)
__pycache__/
*.py[cod]
.venv/

# Captured screenshots from local testing of app-store-screenshots
screenshots/
