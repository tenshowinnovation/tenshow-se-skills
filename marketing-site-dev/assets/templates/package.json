{
  "name": "CHANGE-ME",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",

    "setup:bucket":  "node --env-file-if-exists=.env scripts/setup-bucket.mjs",
    "setup:cdn":     "node --env-file-if-exists=.env scripts/cdn-setup.mjs",
    "deploy":        "pnpm build && node --env-file-if-exists=.env scripts/deploy.mjs",
    "deploy:upload": "node --env-file-if-exists=.env scripts/deploy.mjs",
    "cdn:refresh":   "node --env-file-if-exists=.env scripts/cdn-refresh.mjs"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^6.3.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@volcengine/tos-sdk": "^2.9.0",
    "mime": "^4.0.4",
    "typescript": "^5.6.3"
  }
}
